// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int              @id @default(autoincrement())
  email           String           @unique
  name            String?
  posts           Pet[]
  inquiries       Inquiry[]
  inquiriesOnPets InquiriesOnPet[]
}

model Pet {
  id        Int       @id @default(autoincrement())
  name      String
  type      String
  age       Int?
  breed     String?
  fosterId  Int
  foster    User      @relation(fields: [fosterId], references: [id])
  inquiries Inquiry[]
  images    Image[]
}

model Image {
  id    Int    @id @default(autoincrement())
  url   String
  pet   Pet    @relation(fields: [petId], references: [id])
  petId Int
}

model Inquiry {
  id              Int              @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String
  phone           String?
  fosterId        Int
  foster          User             @relation(fields: [fosterId], references: [id])
  petId           Int
  pet             Pet              @relation(fields: [petId], references: [id])
  inquiriesOnPets InquiriesOnPet[]
}

model InquiriesOnPet {
  pet        User     @relation(fields: [petId], references: [id])
  petId      Int
  inquiry    Inquiry  @relation(fields: [inquiryId], references: [id])
  inquiryId  Int
  assignedAt DateTime @default(now())
  assignedBy String

  @@id([petId, inquiryId])
}
